{
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "always"
  },
  "editor.tabSize": 2,
  "todo-tree.general.tags": ["TODO", "FIXME", "BUG", "NOTE"],
  "todo-tree.highlights.customHighlight": {
    "NOTE": {
      "icon": "note",
      "type": "tag",
      "foreground": "#000",
      "background": "#61d1e2",
      "opacity": 50,
      "iconColour": "#304be5"
    }
  },
}
